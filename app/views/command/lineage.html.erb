<div class="text-center">
<h2>Execution Audit</h2>
<h4><i>Tagged Commands</i></h4>
</div>

<div class="d-flex aligns-items-center justify-content-center card text-center w-75 mx-auto">
   <% @lineage.each do |linobj| %>
    <div class="card-header">
      <ul class="nav nav-tabs card-header-tabs">
        <li class="nav-item">
          <a class="nav-link active" aria-current="true" href="#"><%= linobj.status %> - <strong>TRACKED</strong></a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/commands/<%= linobj.id %>"><%= linobj.uuid %></a>
        </li>
      </ul>
    </div>
    <div class="card-body">
      <h5 class="card-title"><%=linobj.name%></h5>
      <p class="card-text"><%=linobj.stdout%></p>
    </div>
    <% end %>
  </div>

